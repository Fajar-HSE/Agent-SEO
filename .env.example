# ============================================================
# SEO Agent Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# LLM Providers (set at least one)
# ------------------------------------------------------------------

# HuggingFace Inference API — free tier available
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here

# OpenRouter — multi-model gateway, has free tier
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama — runs locally, no key needed
# Just make sure Ollama is running: ollama serve
# (No env var needed)

# ------------------------------------------------------------------
# WordPress Publishing (Phase 3)
# ------------------------------------------------------------------

# WordPress site URL (no trailing slash)
WP_URL=https://your-site.com

# WordPress username
WP_USERNAME=your_username

# WordPress Application Password (Settings > Users > Application Passwords)
# Format: xxxx xxxx xxxx xxxx xxxx xxxx (spaces are OK — stripped automatically)
WP_APP_PASSWORD=your_application_password_here

# ------------------------------------------------------------------
# Workflow Behavior
# ------------------------------------------------------------------

# Set to 1 to skip human approval prompt (useful for CI/automation)
NO_HUMAN_APPROVAL=0

# ------------------------------------------------------------------
# Optional: Override defaults
# ------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
